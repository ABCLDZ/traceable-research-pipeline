{
  "$defs": {
    "EvidenceType": {
      "enum": [
        "quantitative",
        "qualitative",
        "numeric_table",
        "forecast",
        "policy_target",
        "management_statement",
        "third_party_claim"
      ],
      "title": "EvidenceType",
      "type": "string"
    },
    "ReviewDecision": {
      "enum": [
        "pending",
        "admit",
        "reject",
        "merge",
        "revise"
      ],
      "title": "ReviewDecision",
      "type": "string"
    },
    "ReviewItem": {
      "properties": {
        "card_id": {
          "title": "Card Id",
          "type": "string"
        },
        "authoritative_card_sha256": {
          "title": "Authoritative Card Sha256",
          "type": "string"
        },
        "document_id": {
          "title": "Document Id",
          "type": "string"
        },
        "authoritative_document_sha256": {
          "title": "Authoritative Document Sha256",
          "type": "string"
        },
        "claim": {
          "title": "Claim",
          "type": "string"
        },
        "original_excerpt": {
          "title": "Original Excerpt",
          "type": "string"
        },
        "evidence_type": {
          "$ref": "#/$defs/EvidenceType"
        },
        "automatic_blockers": {
          "items": {
            "type": "string"
          },
          "title": "Automatic Blockers",
          "type": "array"
        },
        "automatic_warnings": {
          "items": {
            "type": "string"
          },
          "title": "Automatic Warnings",
          "type": "array"
        },
        "source_parse_quality": {
          "default": "unknown",
          "title": "Source Parse Quality",
          "type": "string"
        },
        "manual_source_review_required": {
          "default": false,
          "title": "Manual Source Review Required",
          "type": "boolean"
        },
        "source_quality_signals": {
          "items": {
            "type": "string"
          },
          "title": "Source Quality Signals",
          "type": "array"
        },
        "decision": {
          "$ref": "#/$defs/ReviewDecision",
          "default": "pending"
        },
        "merge_group": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Merge Group"
        },
        "record_title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Record Title"
        },
        "revised_summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Revised Summary"
        },
        "time_range": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Time Range"
        },
        "geography": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Geography"
        },
        "industry_scope": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Industry Scope"
        },
        "applicability": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Applicability"
        },
        "prohibited_extrapolations": {
          "items": {
            "type": "string"
          },
          "title": "Prohibited Extrapolations",
          "type": "array"
        },
        "review_notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review Notes"
        },
        "manual_override_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Manual Override Reason"
        }
      },
      "required": [
        "card_id",
        "authoritative_card_sha256",
        "document_id",
        "authoritative_document_sha256",
        "claim",
        "original_excerpt",
        "evidence_type"
      ],
      "title": "ReviewItem",
      "type": "object"
    }
  },
  "properties": {
    "schema_version": {
      "default": "0.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "research_question": {
      "title": "Research Question",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "instructions": {
      "items": {
        "type": "string"
      },
      "title": "Instructions",
      "type": "array"
    },
    "items": {
      "items": {
        "$ref": "#/$defs/ReviewItem"
      },
      "title": "Items",
      "type": "array"
    }
  },
  "required": [
    "project_id",
    "research_question",
    "created_at",
    "instructions",
    "items"
  ],
  "title": "ReviewPack",
  "type": "object"
}
